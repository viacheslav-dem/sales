# Закрыть доступ к служебным файлам и папкам
<FilesMatch "\.(db|json|lock|md)$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On
    # Запретить доступ к папке data/
    RewriteRule ^data/ - [F,L]
    # Запретить прямой доступ к vendor/
    RewriteRule ^vendor/ - [F,L]
</IfModule>

# Отключить показ содержимого директорий
Options -Indexes

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "same-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # CSP: разрешены inline scripts/styles (требуется текущим кодом), шрифты локальные
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self' https://cloudflareinsights.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
</IfModule>
